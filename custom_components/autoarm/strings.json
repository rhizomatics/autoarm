{
    "title":"AutoArm",
    "config": {
        "step": {
            "user": {
                "title": "Select Alarm Panel",
                "data": {
                    "alarm_panel": "Alarm Control Panel to manage"
                }
            },
            "calendars": {
                "title": "Select Calendars",
                "data": {
                    "calendar_entities": "Calendars to use for arming schedules"
                }
            },
            "persons": {
                "title": "Select Persons",
                "data": {
                    "person_entities": "People for occupancy based arming"
                }
            }
        },
        "abort": {
            "already_configured": "[%key:common::config_flow::abort::already_configured_service%]"
        }
    },
    "options": {
        "step": {
            "init": {
                "title": "Auto Arm Options",
                "data": {
                    "calendar_entities": "Calendars to use for arming schedules",
                    "person_entities": "People for occupancy based arming",
                    "occupancy_default_day": "Default arming state when occupied during day",
                    "occupancy_default_night": "Default arming state when occupied at night",
                    "no_event_mode": "Arming state when a calendar event ends"
                },
                "sections": {
                    "calendar_options": {
                        "name": "Calendar Occupancy Override",
                        "data": {
                            "calendar_occupancy_override_states": "States that occupancy can override"
                        },
                        "data_description": {
                            "calendar_occupancy_override_states": "When a calendar event sets one of these states, occupancy changes (arrivals and departures) can still update the alarm state. For example, if the calendar says Disarmed but everyone leaves, it will switch to Armed Away."
                        }
                    },
                    "notify_options": {
                        "name": "Notifications",
                        "data": {
                            "notify_enabled": "Notifications Enabled",
                            "notify_action": "Notification Action",
                            "notify_targets": "Notification Targets"
                        },
                        "data_description": {
                            "notify_enabled": "Enable notifications for alarm state changes",
                            "notify_action": "Home Assistant action (service) to use to notify",
                            "notify_targets": "List of addresses or notify entities to notify, can be left blank for Supernotify"
                        }
                    },
                    "sunrise_options": {
                        "name": "Sunrise Constraints",
                        "data": {
                            "sunrise_earliest": "Earliest",
                            "sunrise_latest": "Latest"
                        },
                        "data_description": {
                            "sunrise_earliest": "Earliest",
                            "sunrise_latest": "Latest"
                        }
                    },
                    "sunset_options": {
                        "name": "Sunset Constraints",
                        "data": {
                            "sunset_earliest": "Earliest time for sunrise",
                            "sunset_latest": "Latest time for sunrise"
                        },
                        "data_description": {
                             "sunset_earliest": "Earliest time for sunset",
                            "sunset_latest": "Latest time for sunset"
                        }
                    }
                }
            }
        }
    },
    "services": {
        "reload": {
            "name": "[%key:common::action::reload%]",
            "description": "Reloads autoarm configuration."
        }
    },
    "issues":{
        "transition_condition":{
            "title":"Invalid Transition Condition",
            "description":"Transition condition for {state} failed to validate with an error ({error})"
        },
        "yaml_core_config_deprecated": {
            "title": "YAML core configuration is deprecated",
            "description": "Core AutoArm settings (alarm_panel, occupancy, calendars) have been migrated to the UI config entry. Remove these from your YAML configuration and use the UI to manage them. Advanced settings (transitions, buttons, notify, diurnal, rate_limit) can remain in YAML."
        }
    }
}
